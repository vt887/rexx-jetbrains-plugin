<idea-plugin>
    <id>org.rexxlang.rexx</id>
    <name>Rexx Language Support</name>
    <vendor email="tymoshv@example.com">tymoshv</vendor>

    <description><![CDATA[
        Rexx language support for IntelliJ Platform IDEs: file type registration,
        lexer-backed tokenization, syntax highlighting, keyword completion,
        run configuration (regina / rexx / ooRexx), and code formatter.
    ]]></description>

    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType
            name="Rexx"
            language="Rexx"
            implementationClass="org.lang.rexx.RexxFileType"
            fieldName="INSTANCE"
            extensions="rexx;rex;rx"/>
        <lang.syntaxHighlighterFactory
            language="Rexx"
            implementationClass="org.lang.rexx.RexxSyntaxHighlighterFactory"/>
        <lang.parserDefinition
            language="Rexx"
            implementationClass="org.lang.rexx.RexxParserDefinition"/>
        <completion.contributor
            language="Rexx"
            implementationClass="org.lang.rexx.RexxCompletionContributor"/>
        <annotator
            language="Rexx"
            implementationClass="org.lang.rexx.RexxCommentTagAnnotator"/>
        <configurationType implementation="org.lang.rexx.run.RexxRunConfigurationType"/>
        <lang.formatter
            language="Rexx"
            implementationClass="org.lang.rexx.format.RexxFormattingModelBuilder"/>
        <preFormatProcessor implementation="org.lang.rexx.format.RexxPreFormatProcessor"/>
        <codeStyleSettingsProvider implementation="org.lang.rexx.format.RexxCodeStyleSettingsProvider"/>
        <langCodeStyleSettingsProvider implementation="org.lang.rexx.format.RexxLanguageCodeStyleSettingsProvider"/>
        <colorSettingsPage implementation="org.lang.rexx.RexxColorSettingsPage"/>
    </extensions>
</idea-plugin>
